    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@smithy/core": "^3.23.14",
    "@smithy/node-http-handler": "^4.5.2",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.3",
    "cacache": "^19.0.1",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "cli-highlight": "^2.1.11",
    "color-diff-napi": "^0.0.1",
    "diff": "^7.0.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
