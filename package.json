{
  "name": "universal-agent",
  "version": "1.2.74",
  "description": "🤖 A universal multi-domain AI Agent CLI - claude-code core engine with multi-LLM support (OpenAI, Gemini, Ollama, Anthropic)",
  "type": "module",
  "bin": {
    "uagent": "./dist/entrypoints/cli.js",
    "claude": "./dist/entrypoints/cli.js"
  },
  "scripts": {
    "build:mcp": "cd src/builtin-plugins/omo-agents/mcp-server && npm install --ignore-scripts 2>/dev/null; npx esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs",
    "build": "npm run build:mcp && bun build src/entrypoints/cli.tsx --outdir dist-bun --target bun --root . --external react --external react-reconciler --external ink && mkdir -p dist/entrypoints && cp dist-bun/src/entrypoints/cli.js dist/entrypoints/cli.js && python3 -c \"import sys; c=open('dist/entrypoints/cli.js').read(); open('dist/entrypoints/cli.js','w').write(('#!/usr/bin/env bun\\n'+c[8:]) if c.startswith('// @bun') else (c if c.startswith('#!') else '#!/usr/bin/env bun\\n'+c))\" && chmod +x dist/entrypoints/cli.js && rsync -a --exclude='node_modules' --exclude='*.ts' --exclude='dist' --include='*/' --include='*.md' --include='*.json' --include='*.cjs' --include='*.js' --exclude='*' src/builtin-plugins/ dist/builtin-plugins/ && mkdir -p dist/builtin-plugins/omo-agents/mcp-server/dist && cp src/builtin-plugins/omo-agents/mcp-server/dist/index.cjs dist/builtin-plugins/omo-agents/mcp-server/dist/index.cjs",
    "dev": "bun --watch src/entrypoints/cli.tsx",
    "start": "bun src/entrypoints/cli.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "claude",
    "claude-code",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "multi-model"
  ],
  "author": "wb_guozhongming",
  "license": "MIT",
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@anthropic-ai/bedrock-sdk": "^0.27.0",
    "@anthropic-ai/foundry-sdk": "^0.2.3",
    "@anthropic-ai/sdk": "^0.40.0",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@aws-sdk/client-bedrock": "^3.1025.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1025.0",
    "@aws-sdk/client-sts": "^3.1025.0",
    "@aws-sdk/credential-provider-node": "^3.972.29",
    "@azure/identity": "^4.13.1",
    "@commander-js/extra-typings": "^13.0.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.214.0",
    "@opentelemetry/exporter-prometheus": "^0.214.0",
