{
  "name": "universal-agent",
  "version": "0.1.0",
  "description": "🤖 A universal multi-domain AI Agent CLI - supports data analysis, programming, customer service and more",
  "type": "module",
  "bin": {
    "uagent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "data-analysis",
    "llm",
    "openai",
    "anthropic",
    "multi-domain"
  ],
  "author": "wb_guozhongming",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "inquirer": "^12.3.0",
    "openai": "^4.77.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "table": "^6.8.2",
    "node-fetch": "^3.3.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "eslint": "^9.18.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
